# ============================================================
# .env.production.example — frontend env for production builds.
# Copy to `.env.production` on the build host (Vercel dashboard) and
# set the real values. NEVER commit `.env.production`.
# ============================================================

# Backend API base URL. The Vercel rewrite in vercel.json forwards
# `/api/*` to the Render backend already, so on Vercel the default
# `/api` is fine and this var stays unset. Override only if you're
# hosting the frontend on a domain that doesn't proxy `/api`.
# VITE_API_BASE_URL=https://csc-ostwald-api.onrender.com/api

# MSW mocks must NEVER run in production — left unset means real backend.
# VITE_USE_MOCKS=false

# ── Feature flags (LAUNCH STATE) ────────────────────────────
# Both are OFF for the initial launch. A flag is disabled only when its
# value is exactly the string "false".
#
# VITE_PAYMENTS_ENABLED=false
#   Hides the paid Jeunesse registration flow. MUST mirror the API's
#   PAYMENTS_ENABLED env var. Flip both to `true` once the HelloAsso
#   organization account + API keys are live.
VITE_PAYMENTS_ENABLED=false
#
# VITE_NEWSLETTER_ENABLED=false
#   Hides the newsletter form in the footer. Flip to `true` once an SMTP
#   provider is wired so the double opt-in confirmation email can be sent.
VITE_NEWSLETTER_ENABLED=false
