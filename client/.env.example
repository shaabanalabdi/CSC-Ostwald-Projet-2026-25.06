# ============================================================
# .env.example — frontend env for local development.
# Copy to `.env` and tweak. Production values live in
# `.env.production.example` (and ultimately in the Vercel dashboard).
# ============================================================

# Public canonical site URL (used in PageSEO + JSON-LD og:url).
# Defaults to https://csc-ostwald.fr if unset.
VITE_SITE_URL=http://localhost:5173

# Backend API base URL. Defaults to `/api` (works in dev because the
# Vite proxy forwards /api/* to localhost:3001 — see vite.config.js).
# Set this only if you need to hit a remote API from the local frontend.
# VITE_API_BASE_URL=http://localhost:3001/api

# Set to `true` to enable MSW handlers (mocks the backend in-browser).
# DEV-ONLY: this is ignored in production builds.
# VITE_USE_MOCKS=false

# ── Feature flags ───────────────────────────────────────────
# Both default to enabled (only the literal string "false" disables a
# flag). Keep them unset in dev so the full UI is testable.
#
# VITE_PAYMENTS_ENABLED — paid Jeunesse registration via HelloAsso.
#   MUST mirror the API's PAYMENTS_ENABLED on every deployment.
# VITE_NEWSLETTER_ENABLED — newsletter form in the footer.
#   Set to false until an SMTP provider is wired (double opt-in needs it).
# VITE_PAYMENTS_ENABLED=true
# VITE_NEWSLETTER_ENABLED=true
