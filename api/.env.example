# ============================================================
# CSC Ostwald API — Environment template
# Copy this file to `.env` and fill in real values. NEVER commit .env.
# ============================================================

# ─── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Frontend origin(s). Single URL for dev, comma-separated for prod when
# both the apex and www subdomains serve the site, e.g.:
#   CORS_ORIGIN=https://csc-ostwald.fr,https://www.csc-ostwald.fr
CORS_ORIGIN=http://localhost:5173

# ─── Database (MySQL) ──────────────────────────────────────
# Native MySQL: leave DB_PASSWORD empty (the default for a fresh
# local install). Docker (recommended for dev): the root password is
# `dev` — see ../docker-compose.yml.
#
# Production note: in deploy/docker-compose.prod.yml the API connects
# as the least-privileged DB_USER (granted only on ${DB_NAME}.*). The
# separate DB_ROOT_PASSWORD lives ONLY in deploy/.env (never injected
# into the API container) and is used exclusively by backup.sh.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=dev
DB_NAME=csc_ostwald
# Production only — root password used by the daily mysqldump.
# Leave commented in dev. Pick something different from DB_PASSWORD.
# DB_ROOT_PASSWORD=

# ─── JWT (admin auth) ──────────────────────────────────────
# Generate a strong secret for production: `openssl rand -base64 64`
JWT_SECRET=change-me-to-a-long-random-string-min-64-chars
# Token lifetime in seconds (default 24h)
JWT_TTL_SECONDS=86400
# Cookie name carrying the JWT (rarely overridden — only needed when
# several CSC services share a domain).
COOKIE_NAME=jwt_token
# SameSite for the JWT cookie. 'strict' (default) works when the frontend
# proxies /api/* through Vercel rewrites (recommended). Use 'none' only
# if the API runs on a different site (e.g. api.csc-ostwald.fr); the
# server then refuses to start without NODE_ENV=production + HTTPS.
COOKIE_SAMESITE=strict

# ─── HelloAsso (payment for Jeunesse registrations) ────────
# PAYMENTS_ENABLED is the master switch for the paid-registration feature.
#   true  (default) → /api/payment/* routes are mounted; in production
#                     HELLOASSO_MODE must be `real` with all four
#                     credentials set, or the API refuses to boot.
#   false           → /api/payment/* routes are NOT mounted and the
#                     production HelloAsso checks are skipped, so the API
#                     boots WITHOUT HelloAsso. Use this to launch the site
#                     before the HelloAsso organization account is ready.
# Keep this in sync with the frontend's VITE_PAYMENTS_ENABLED.
PAYMENTS_ENABLED=true

# `mock` = local stub, no external API call (dev ONLY).
# `real` = call HelloAsso API.
#
# When PAYMENTS_ENABLED=true, production (NODE_ENV=production) REFUSES TO
# BOOT unless HELLOASSO_MODE=real. The previous "ship mock mode to prod"
# stance recorded fake "paid" registrations without charging anyone AND
# exposed the /mock-success open-redirect — both blocked at startup now.
HELLOASSO_MODE=mock

# Base URL — override for sandbox testing only.
HELLOASSO_BASE_URL=https://api.helloasso.com

# Credentials from your HelloAsso organization → API access page.
HELLOASSO_CLIENT_ID=
HELLOASSO_CLIENT_SECRET=
HELLOASSO_ORG_SLUG=csc-ostwald

# Shared secret used to verify webhook signatures (HelloAsso dashboard).
HELLOASSO_WEBHOOK_SECRET=

# Where HelloAsso redirects the user after checkout (must match the
# public frontend URL in production).
HELLOASSO_RETURN_URL=http://localhost:5173/jeunesse/inscription-confirmee
HELLOASSO_CANCEL_URL=http://localhost:5173/jeunesse
