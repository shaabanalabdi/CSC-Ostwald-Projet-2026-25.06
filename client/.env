VITE_SITE_URL=https://csc-ostwald.fr
# Override only if your local API is NOT proxied by Vite (dev default is
# vite.config.js → server.proxy /api → localhost:3001). The client code
# reads `VITE_API_BASE_URL`, NOT `VITE_API_URL` — keep the name in sync
# with client/src/api/client.js otherwise the override silently does nothing.
# VITE_API_BASE_URL=http://localhost:3001/api
