# =====================================================================
# .env.example — Template for the production .env on the OVH VPS.
#
# Copy on the VPS:
#   cp deploy/.env.example deploy/.env
#   nano deploy/.env       # fill in every <CHANGE-ME>
#   chmod 600 deploy/.env  # only root can read
#
# NEVER commit .env. Add it to .gitignore (already done at repo root).
# =====================================================================

# ── Server ──────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
# Production domain. Comma-separated if you serve both apex + www.
CORS_ORIGIN=https://csc-ostwald.fr,https://www.csc-ostwald.fr

# ── Database (MySQL container on the same Docker network) ───────────
# DB_HOST is set to `mysql` in docker-compose.prod.yml — don't override.
DB_USER=root
# Generate a strong password: `openssl rand -base64 32`
DB_PASSWORD=<CHANGE-ME-strong-random-password>
DB_NAME=csc_ostwald
DB_PORT=3306

# ── JWT (admin auth) ────────────────────────────────────────────────
# REQUIRED: at least 32 chars. Generate: `openssl rand -base64 64`
JWT_SECRET=<CHANGE-ME-min-32-chars-via-openssl-rand-base64-64>
JWT_TTL_SECONDS=86400
COOKIE_NAME=jwt_token
# `strict` works because nginx proxies /api/* same-origin to the API.
COOKIE_SAMESITE=strict

# ── HelloAsso — paid Jeunesse registration ──────────────────────────
# LAUNCH STATE: the site is published BEFORE the HelloAsso organization
# account is ready, so the paid-registration feature is OFF.
#
#   PAYMENTS_ENABLED=false → /api/payment/* routes are not mounted; the
#     API boots fine without HelloAsso credentials. The frontend build
#     MUST set VITE_PAYMENTS_ENABLED=false to match (hides the
#     "S'inscrire" button on Jeunesse activities).
#
# TO ENABLE PAYMENTS LATER:
#   1. Create the HelloAsso organization account.
#   2. Set PAYMENTS_ENABLED=true below.
#   3. Keep HELLOASSO_MODE=real and fill the four <CHANGE-ME> values from
#      your HelloAsso organization -> API access page. The webhook secret
#      must match the HelloAsso dashboard (webhook URL ->
#      https://csc-ostwald.fr/api/payment/webhook).
#   4. Rebuild the frontend with VITE_PAYMENTS_ENABLED=true.
# When PAYMENTS_ENABLED=true the API REFUSES TO BOOT if HELLOASSO_MODE is
# not `real` or any credential is empty — a deliberate fail-fast.
PAYMENTS_ENABLED=false

HELLOASSO_MODE=real
HELLOASSO_BASE_URL=https://api.helloasso.com
HELLOASSO_CLIENT_ID=<CHANGE-ME-when-PAYMENTS_ENABLED=true>
HELLOASSO_CLIENT_SECRET=<CHANGE-ME-when-PAYMENTS_ENABLED=true>
HELLOASSO_ORG_SLUG=csc-ostwald
HELLOASSO_WEBHOOK_SECRET=<CHANGE-ME-when-PAYMENTS_ENABLED=true>
HELLOASSO_RETURN_URL=https://csc-ostwald.fr/jeunesse/inscription-confirmee
HELLOASSO_CANCEL_URL=https://csc-ostwald.fr/jeunesse

# ── Optional: where backup.sh uploads daily mysqldump ───────────────
# Leave empty to skip the upload (backups still saved locally under
# /srv/csc-ostwald/backups/).
# Example for OVH Object Storage (Swift S3-compatible):
#   BACKUP_S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net
#   BACKUP_S3_BUCKET=csc-ostwald-backups
#   BACKUP_S3_ACCESS_KEY=<from OVH Public Cloud > Object Storage>
#   BACKUP_S3_SECRET_KEY=<from OVH Public Cloud > Object Storage>
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
